# (at your option) any later version.
#
# All patched behaviour is gated on the kernel boot parameter:
#   amd_vfio_pass_fix=1
# Without that parameter the kernel behaves as stock.
diff --git a/drivers/iommu/iommu.c b/drivers/iommu/iommu.c
index ee83850c7060..cc63ee614c9c 100644
--- a/drivers/iommu/iommu.c
+++ b/drivers/iommu/iommu.c
@@ -38,6 +38,20 @@
 #include "dma-iommu.h"
 #include "iommu-priv.h"
 
+bool amd_vfio_pass_fix __read_mostly;
+
+static int __init amd_vfio_pass_fix_setup(char *s)
+{
+	unsigned long val;
+	if (!kstrtoul(s, 0, &val))
+		amd_vfio_pass_fix = !!val;
+	return 1;
+}
+__setup("amd_vfio_pass_fix=", amd_vfio_pass_fix_setup);
+
+/* Export so vfio_iommu_type1.c can read the same flag */
+EXPORT_SYMBOL_GPL(amd_vfio_pass_fix);
+
 static struct kset *iommu_group_kset;
 static DEFINE_IDA(iommu_group_ida);
 static DEFINE_IDA(iommu_global_pasid_ida);
diff --git a/drivers/vfio/vfio_iommu_type1.c b/drivers/vfio/vfio_iommu_type1.c
index 03cefdf99a4a..4913afc01fb3 100644
--- a/drivers/vfio/vfio_iommu_type1.c
+++ b/drivers/vfio/vfio_iommu_type1.c
@@ -122,6 +122,9 @@ struct vfio_iova {
 	dma_addr_t		end;
 };
 
+/* Declared and initialised in drivers/iommu/iommu.c */
+extern bool amd_vfio_pass_fix;
+
 /*
  * Guest RAM pinning working set or DMA target
  */
@@ -766,7 +769,8 @@ static long vfio_pin_pages_remote(struct vfio_dma *dma, unsigned long vaddr,
 			 * the user.
 			 */
 			if (acct_pages) {
-				if (!dma->lock_cap &&
+				/* patched: skip memlock check when amd_vfio_pass_fix=1 */
+				if (!amd_vfio_pass_fix && !dma->lock_cap && limit != RLIM_INFINITY &&
 				    mm->locked_vm + lock_acct + acct_pages > limit) {
 					pr_warn("%s: RLIMIT_MEMLOCK (%ld) exceeded\n",
 						__func__, limit << PAGE_SHIFT);
@@ -1775,7 +1779,8 @@ static int vfio_dma_do_map(struct vfio_iommu *iommu,
 	 */
 	get_task_struct(current->group_leader);
 	dma->task = current->group_leader;
-	dma->lock_cap = capable(CAP_IPC_LOCK);
+	/* patched: always allow locking when amd_vfio_pass_fix=1 */
+	dma->lock_cap = amd_vfio_pass_fix ? true : capable(CAP_IPC_LOCK);
 	dma->mm = current->mm;
 	mmgrab(dma->mm);
 
@@ -2140,6 +2145,12 @@ static int vfio_iommu_resv_exclude(struct list_head *iova,
 		if (resv->type == IOMMU_RESV_DIRECT_RELAXABLE)
 			continue;
 
+		/* patched: skip excluding direct regions at address 0 when
+		 * amd_vfio_pass_fix=1, to allow QEMU DMA mapping. */
+		if (amd_vfio_pass_fix &&
+		    resv->type == IOMMU_RESV_DIRECT && resv->start == 0)
+			continue;
+
 		start = resv->start;
 		end = resv->start + resv->length - 1;
 
@@ -2230,6 +2241,11 @@ static int vfio_iommu_domain_alloc(struct device *dev, void *data)
 {
 	struct iommu_domain **domain = data;
 
+	/* patched: clear require_direct before domain allocation so we get a
+	 * DMA domain rather than an identity domain (amd_vfio_pass_fix=1 only) */
+	if (amd_vfio_pass_fix && dev->iommu)
+		dev->iommu->require_direct = 0;
+
 	*domain = iommu_paging_domain_alloc(dev);
 	return 1; /* Don't iterate */
 }
